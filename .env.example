# AI API 配置文件
# 
# 推荐使用 豆包（火山引擎）
# 申请地址: https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
#
# 也支持 DeepSeek
# 申请地址: https://platform.deepseek.com/api_keys

# AI 服务商 (douban 或 deepseek)
VITE_AI_PROVIDER=douban

# API Key（必填）
VITE_AI_API_KEY=your_api_key_here

# 模型名称（可选，不填使用默认）
# 豆包可选: doubao-seed-2.0-lite（推荐）
# DeepSeek可选: deepseek-chat
# VITE_AI_MODEL=doubao-seed-2.0-lite
